# ── Discord app ──────────────────────────────────────────────
# From https://discord.com/developers/applications → Your App
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Your server's guild ID (right-click server icon → Copy Server ID)
DISCORD_GUILD_ID=your_guild_id_here

# Channel where status-change embeds are posted automatically (outbound)
DISCORD_STATUS_CHANNEL_ID=your_status_channel_id_here

# Channel the bot LISTENS TO for incoming "Status Change" embeds from your
# webhook bot — right-click the "Webhook Bot Updates" channel → Copy Channel ID
# IMPORTANT: In the Discord Developer Portal → Bot → Privileged Gateway Intents
#            you must enable "Message Content Intent" for this to work.
WEBHOOK_UPDATES_CHANNEL_ID=your_webhook_updates_channel_id_here

# (Optional) Only members with this role ID can use slash commands.
# Leave blank to require Manage Server permission only.
ALLOWED_ROLE_ID=

# ── Site connection ───────────────────────────────────────────
SITE_URL=https://cheatparadise.com

# Must match BOT_API_KEY in Vercel environment variables
BOT_API_KEY=generate_a_long_random_secret_here
