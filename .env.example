SELLAUTH_SHOP_ID=your_shop_id_here
SELLAUTH_API_KEY=your_api_key_here
SELLAUTH_API_BASE_URL=https://api.sellauth.com

# Emergency lock switch (set true to immediately pause checkout)
CHECKOUT_FORCE_DISABLE=false

# Optional comma-separated image hosts (HTTPS only)
# Example: api.sellauth.com,cdn.yourdomain.com,**.mysellauth.com
NEXT_IMAGE_REMOTE_HOSTS=api.sellauth.com,**.mysellauth.com

NEXT_PUBLIC_DISCORD_URL=https://discord.gg/yourserver
NEXT_PUBLIC_SUPPORT_URL=https://discord.gg/yourserver

# reselling.pro delivery API key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Set this in Cloudflare Pages > Settings > Environment Variables (or Workers secrets)
# For local dev only: add to .env.local (never commit .env.local)
DELIVERY_API_KEY=your_delivery_api_key_here

# Optional: SellAuth webhook secret for signature verification
# Generate a random string, paste it here AND in SellAuth dashboard > Webhooks > Secret
SELLAUTH_WEBHOOK_SECRET=your_webhook_secret_here
