SELLAUTH_SHOP_ID=your_shop_id_here
SELLAUTH_API_KEY=your_api_key_here
SELLAUTH_API_BASE_URL=https://api.sellauth.com

# Emergency lock switch (set true to immediately pause checkout)
CHECKOUT_FORCE_DISABLE=false

# Optional comma-separated image hosts (HTTPS only)
# Example: api.sellauth.com,cdn.yourdomain.com,**.mysellauth.com
NEXT_IMAGE_REMOTE_HOSTS=api.sellauth.com,**.mysellauth.com

NEXT_PUBLIC_DISCORD_URL=https://discord.gg/yourserver
NEXT_PUBLIC_SUPPORT_URL=https://discord.gg/yourserver

# reselling.pro delivery API key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Set this in Cloudflare Pages > Settings > Environment Variables (or Workers secrets)
# For local dev only: add to .env.local (never commit .env.local)
DELIVERY_API_KEY=your_delivery_api_key_here

# REQUIRED: SellAuth webhook secret for signature verification
# Generate a random string, paste it here AND in SellAuth dashboard > Webhooks > Secret
# Webhooks are blocked until this is set.
SELLAUTH_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Email Notifications (Resend) ───────────────────────────────────────────
# Sign up at https://resend.com — get your API key from the dashboard
# If unset, email notifications are skipped (dev/staging only)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=CheatParadise <noreply@yourdomain.com>

# ─── Error Tracking (optional) ──────────────────────────────────────────────
# Sign up at https://sentry.io — DSN found in Project Settings > Client Keys
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ─── Supabase (user accounts, auth, database) ───────────────────────────────
# Create a free project at https://supabase.com
# Find these in: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── PostHog Analytics (free: 1M events/month) ──────────────────────────────
# Sign up at https://posthog.com — get your key from Project Settings > Project API Key
# Leave blank to disable analytics entirely
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
